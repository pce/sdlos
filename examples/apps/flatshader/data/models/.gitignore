# Model files: .glb  .gltf  .obj  .fbx
#
# Large binary assets should use Git LFS to avoid bloating the repository:
#   git lfs track "*.glb"
#   git lfs track "*.gltf"
#   git lfs track "*.fbx"
# Then commit the .gitattributes file that git lfs generates.
