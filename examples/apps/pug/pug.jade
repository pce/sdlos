// =============================================================================
// pug.jade  —  UI scene for the pug app
// Generated by sdlos create [pug].  Edit freely.
// CSS styles → pug.css  (loaded automatically by jade_host)
// =============================================================================
//
// Layout
// ------
// The FrameGraph (data/pipeline.pug) renders the visual background for this app.
// This jade scene is a transparent overlay — only the .hud-panel has a visible
// fill.  Resize or reposition .hud-panel in pug.css to taste.
//
// Node ID reference  (used by tree.findById() in the behavior)
// ─────────────────────────────────────────────────────────────
//   root              — window root column  (transparent background)
//   hud-panel         — floating glass control panel
//   chip-default      — theme chip: default (no class set)
//   chip-night        — theme chip: "night" CSS class
//   chip-vivid        — theme chip: "vivid" CSS class
//   chip-normal       — quality chip: normal (full pipeline)
//   chip-low          — quality chip: low-power (disables vignette)
//   val-bg-speed      — live display of bg pass "speed" param
//   val-bg-scale      — live display of bg pass "scale" param
//   val-grade-exp     — live display of grade pass "exposure" param
//   val-grade-sat     — live display of grade pass "saturation" param
//
// EventBus topics fired by this scene (onclick handlers)
// ───────────────────────────────────────────────────────
//   pug:theme    — theme chip tapped
//                        payload = data-value  ("default" | "night" | "vivid")
//   pug:quality  — quality chip tapped
//                        payload = "normal" | "low"
//   pug:inc      — +  stepper tapped
//                        payload = "pass:key"  (e.g. "bg:speed")
//   pug:dec      — –  stepper tapped
//                        payload = "pass:key"
//
// Pipeline.pug notes
// ------------------
// The three FrameGraph passes are:
//   pass#bg        — animated FBM noise background         → bg_color (rgba16f)
//   pass#vignette  — radial vignette + edge pulse          → vignette_buffer (rgba16f)
//   pass#grade     — colour grading (exposure/gamma/sat)  → swapchain
//
// Use "sdlos pipeline pug" to visualise the pipeline in the terminal.
// =============================================================================

col(id="root" flexGrow="1")

  // Transparent spacer — FrameGraph renders behind this region.
  div(flexGrow="1")

  // ── HUD panel ─────────────────────────────────────────────────────────────
  col.hud-panel(id="hud-panel")

    // ── Title bar ────────────────────────────────────────────────────────────
    row.hud-title-row
      div.hud-title pug
      div.hud-pill pipeline
    div.hud-divider

    // ── Theme section ─────────────────────────────────────────────────────────
    // Chips fire pug:theme with their data-value.
    // The behavior calls FrameGraph::add_class / remove_class so scoped CSS
    // rules in data/pipeline.css take effect (e.g. pipeline.night #grade { … }).
    div.section-label THEME
    row.chip-row
      div.chip(id="chip-default" onclick="pug:theme" data-value="default") Default
      div.chip(id="chip-night"   onclick="pug:theme" data-value="night")   Night
      div.chip(id="chip-vivid"   onclick="pug:theme" data-value="vivid")   Vivid

    // ── Quality section ───────────────────────────────────────────────────────
    // "Low Power" adds the "low-power" CSS class which disables the vignette
    // pass via pipeline.css — zero GPU cost when a pass is disabled.
    div.section-label QUALITY
    row.chip-row
      div.chip(id="chip-normal" onclick="pug:quality" data-value="normal") Normal
      div.chip(id="chip-low"    onclick="pug:quality" data-value="low")    Low Power

    div.hud-divider

    // ── Live params ───────────────────────────────────────────────────────────
    // +/– steppers call CompiledGraph::patch() so the GPU sees the updated float
    // on the very next frame — no recompile, no string lookup on the hot path.
    div.section-label PARAMS

    // bg › speed
    row.param-row
      div.param-lbl(flexGrow="1") bg › speed
      div.param-btn(onclick="pug:dec" data-value="bg:speed") −
      div.param-val(id="val-bg-speed") 0.40
      div.param-btn(onclick="pug:inc" data-value="bg:speed") +

    // bg › scale
    row.param-row
      div.param-lbl(flexGrow="1") bg › scale
      div.param-btn(onclick="pug:dec" data-value="bg:scale") −
      div.param-val(id="val-bg-scale") 1.50
      div.param-btn(onclick="pug:inc" data-value="bg:scale") +

    // grade › exposure
    row.param-row
      div.param-lbl(flexGrow="1") grade › exp
      div.param-btn(onclick="pug:dec" data-value="grade:exposure") −
      div.param-val(id="val-grade-exp") 1.00
      div.param-btn(onclick="pug:inc" data-value="grade:exposure") +

    // grade › saturation
    row.param-row
      div.param-lbl(flexGrow="1") grade › sat
      div.param-btn(onclick="pug:dec" data-value="grade:saturation") −
      div.param-val(id="val-grade-sat") 1.05
      div.param-btn(onclick="pug:inc" data-value="grade:saturation") +
