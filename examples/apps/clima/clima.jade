//
// Clima weather dashboard


col#clima-root.clima-root(flexGrow="1")

  // City 3D mesh (GPU pre-pass — renders behind all 2D content).
  // src= is set by clima.cc when a city with a mesh is selected.
  // display="none" keeps it out of flex layout; clima.cc sets "block" once
  // the mesh is loaded and "none" again when switching to a mesh-less city.
  scene3d#clima-city-scene(src="" mesh-id="city-mesh" display="none")

  //  Header — icon · app name · [condition select] · [city select] · clock
  //  The two SelectBox widgets (condition + city) are created in C++ and
  //  appended to #clima-cond-host / #clima-city-host at init time.
  row.clima-header
    div.clima-app-icon 🌤
    div.clima-app-name Clima
    div.clima-header-sep
    div#clima-cond-host
    div.clima-header-sep
    div#clima-city-host
    div(flexGrow="1")
    div#clima-time.clima-clock 00:00

  //  Main area: left weather panel + transparent right spacer.
  //  The spacer (flexGrow=1) keeps the card flush-left so the 3-D city mesh
  //  is visible through the right portion of the window.
  row.clima-main(flexGrow="1")

    //  Weather panel — fixed-width glass card
    col#clima-card.clima-card

      // Large weather icon
      div#clima-icon.clima-big-icon ☀️

      // Temperature + condition name + city  (two-column row)
      row.clima-temp-row
        div#clima-temp.clima-temp 24°C
        col.clima-cond-col
          div#clima-condition.clima-condition-name Sunny
          div#clima-city-name.clima-city-label Frankfurt, DE

      // One-line weather description
      div#clima-desc.clima-desc Clear skies, bright sunshine

      // Thin divider
      div.clima-divider

      // Stats row: feels-like · low/high · humidity
      row.clima-stats
        col.stat-box
          div.stat-label Feels like
          div#clima-feels.stat-val 22°C
        col.stat-box
          div.stat-label Low / High
          div#clima-range.stat-val 18° — 27°
        col.stat-box
          div.stat-label Humidity
          div#clima-humidity.stat-val 55%

    //  Transparent spacer — lets the 3-D mesh show through on the right
    div(flexGrow="1")
