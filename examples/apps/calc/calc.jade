col.calculator(backgroundColor="#1c1c1e" flexGrow="1" gap="8")

  div.display(id="display" backgroundColor="#7c7c7e" color="#ffffff" fontSize="52" height="96") 0


  row(backgroundColor="#1c1c1e" flexGrow="1" gap="8")
    div.btn(onclick="calc:fn" data-value="AC"  borderRadius="8" backgroundColor="#6e536e" color="#ffffff" fontSize="22" flexGrow="1") AC
    div.btn(onclick="calc:fn" data-value="±" borderRadius="8" backgroundColor="#636366" color="#ffffff" fontSize="22" flexGrow="1") ±
    div.btn(onclick="calc:fn" data-value="%" borderRadius="8" backgroundColor="#636366" color="#ffffff" fontSize="22" flexGrow="1") %
    div.btn.op(onclick="calc:op" data-value="÷" borderRadius="8" backgroundColor="#e00ea5" color="#ffffff" fontSize="26" flexGrow="1") ÷

  row(backgroundColor="#1c1c1e" flexGrow="1" gap="8")
    div.btn(onclick="calc:digit" data-value="7" borderRadius="8" backgroundColor="#333335" color="#ffffff" fontSize="22" flexGrow="1") 7
    div.btn(onclick="calc:digit" data-value="8" borderRadius="8" backgroundColor="#333335" color="#ffffff" fontSize="22" flexGrow="1") 8
    div.btn(onclick="calc:digit" data-value="9" borderRadius="8" backgroundColor="#333335" color="#ffffff" fontSize="22" flexGrow="1") 9
    div.btn.op(onclick="calc:op" data-value="×" borderRadius="8" backgroundColor="#e00ea5" color="#ffffff" fontSize="26" flexGrow="1") ×

  row(backgroundColor="#1c1c1e" flexGrow="1" gap="8")
    div.btn(onclick="calc:digit" data-value="4" borderRadius="8" backgroundColor="#333335" color="#ffffff" fontSize="22" flexGrow="1") 4
    div.btn(onclick="calc:digit" data-value="5" borderRadius="8" backgroundColor="#333335" color="#ffffff" fontSize="22" flexGrow="1") 5
    div.btn(onclick="calc:digit" data-value="6" borderRadius="8" backgroundColor="#333335" color="#ffffff" fontSize="22" flexGrow="1") 6
    div.btn.op(onclick="calc:op" data-value="−" borderRadius="8" backgroundColor="#e00ea5" color="#ffffff" fontSize="26" flexGrow="1") −

  row(backgroundColor="#1c1c1e" flexGrow="1" gap="8")
    div.btn(onclick="calc:digit" data-value="1" borderRadius="8" backgroundColor="#333335" color="#ffffff" fontSize="22" flexGrow="1") 1
    div.btn(onclick="calc:digit" data-value="2" borderRadius="8" backgroundColor="#333335" color="#ffffff" fontSize="22" flexGrow="1") 2
    div.btn(onclick="calc:digit" data-value="3" borderRadius="8" backgroundColor="#333335" color="#ffffff" fontSize="22" flexGrow="1") 3
    div.btn.op(onclick="calc:op" data-value="+" borderRadius="8" backgroundColor="#e00ea5" color="#ffffff" fontSize="26" flexGrow="1") +

  row(backgroundColor="#1c1c1e" flexGrow="1" gap="8")
    div.btn.zero(onclick="calc:digit" data-value="0" backgroundColor="#636366" color="#ffffff" fontSize="22" flexGrow="2") 0
    div.btn(onclick="calc:digit" data-value="." backgroundColor="#636366" color="#ffffff" fontSize="22" flexGrow="1") .
    div.btn.eq(onclick="calc:push" data-value="=" backgroundColor="#e00ea5" color="#ffffff" fontSize="26" flexGrow="1") =
