col.calculator(backgroundColor="#1c1c1e" flexGrow="1" gap="8")

  div.display(id="display" backgroundColor="#1c1c1e" color="#ffffff" fontSize="52" height="96") 0

  row(backgroundColor="#1c1c1e" flexGrow="1" gap="8")
    div.btn(onclick="calc:fn" data-value="AC" backgroundColor="#636366" color="#ffffff" fontSize="22" flexGrow="1") AC
    div.btn(onclick="calc:fn" data-value="±" backgroundColor="#636366" color="#ffffff" fontSize="22" flexGrow="1") ±
    div.btn(onclick="calc:fn" data-value="%" backgroundColor="#636366" color="#ffffff" fontSize="22" flexGrow="1") %
    div.btn.op(onclick="calc:op" data-value="÷" backgroundColor="#ff9f0a" color="#ffffff" fontSize="26" flexGrow="1") ÷

  row(backgroundColor="#1c1c1e" flexGrow="1" gap="8")
    div.btn(onclick="calc:digit" data-value="7" backgroundColor="#333335" color="#ffffff" fontSize="22" flexGrow="1") 7
    div.btn(onclick="calc:digit" data-value="8" backgroundColor="#333335" color="#ffffff" fontSize="22" flexGrow="1") 8
    div.btn(onclick="calc:digit" data-value="9" backgroundColor="#333335" color="#ffffff" fontSize="22" flexGrow="1") 9
    div.btn.op(onclick="calc:op" data-value="×" backgroundColor="#ff9f0a" color="#ffffff" fontSize="26" flexGrow="1") ×

  row(backgroundColor="#1c1c1e" flexGrow="1" gap="8")
    div.btn(onclick="calc:digit" data-value="4" backgroundColor="#333335" color="#ffffff" fontSize="22" flexGrow="1") 4
    div.btn(onclick="calc:digit" data-value="5" backgroundColor="#333335" color="#ffffff" fontSize="22" flexGrow="1") 5
    div.btn(onclick="calc:digit" data-value="6" backgroundColor="#333335" color="#ffffff" fontSize="22" flexGrow="1") 6
    div.btn.op(onclick="calc:op" data-value="−" backgroundColor="#ff9f0a" color="#ffffff" fontSize="26" flexGrow="1") −

  row(backgroundColor="#1c1c1e" flexGrow="1" gap="8")
    div.btn(onclick="calc:digit" data-value="1" backgroundColor="#333335" color="#ffffff" fontSize="22" flexGrow="1") 1
    div.btn(onclick="calc:digit" data-value="2" backgroundColor="#333335" color="#ffffff" fontSize="22" flexGrow="1") 2
    div.btn(onclick="calc:digit" data-value="3" backgroundColor="#333335" color="#ffffff" fontSize="22" flexGrow="1") 3
    div.btn.op(onclick="calc:op" data-value="+" backgroundColor="#ff9f0a" color="#ffffff" fontSize="26" flexGrow="1") +

  row(backgroundColor="#1c1c1e" flexGrow="1" gap="8")
    div.btn.zero(onclick="calc:digit" data-value="0" backgroundColor="#636366" color="#ffffff" fontSize="22" flexGrow="2") 0
    div.btn(onclick="calc:digit" data-value="." backgroundColor="#636366" color="#ffffff" fontSize="22" flexGrow="1") .
    div.btn.eq(onclick="calc:push" data-value="=" backgroundColor="#ff9f0a" color="#ffffff" fontSize="26" flexGrow="1") =
