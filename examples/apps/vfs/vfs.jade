// =============================================================================
// vfs.jade  —  VFS Explorer + Audio Player  [vfs]
// Generated by sdlos create.  Edit freely.
// CSS styles → vfs.css  (loaded automatically by jade_host)
// =============================================================================
//
// Layout: col root → [3-col main row] + [audio player footer]
//
//   col#root
//   ├── row (flexGrow)
//   │   ├── col.sidebar         — mount scheme selector (left)
//   │   ├── col (flexGrow)      — breadcrumb + file list + content viewer
//   │   └── col.ops-panel       — demo write/read/delete + VFS info (right)
//   └── row.audio-bar           — audio player footer (always visible)
//
// Node ID reference  (used by tree.findById() in the behavior)
// ────────────────────────────────────────────────────────────
//   vfs-schemes        — col of scheme chips (populated at runtime)
//   vfs-path           — breadcrumb / current-path label
//   vfs-file-list      — col receiving dynamic file-entry children
//   vfs-content-title  — label showing the open file name
//   vfs-content        — div showing the file body text
//   vfs-status         — ok/error status line in the ops panel
//   vfs-vfs-info       — mount count label in the ops panel
//   vfs-audio          — invisible audio node whose src= is set by the behavior
//   vfs-audio-title    — now-playing filename label
//   vfs-audio-badge    — "playing" / "stopped" / "ready" pill
//
// EventBus topics fired by this scene (onclick handlers)
// ───────────────────────────────────────────────────────
//   vfs:scheme         — scheme chip clicked   payload = scheme name
//   vfs:open-file      — file entry clicked    payload = entry name
//   vfs:refresh        — re-list current directory
//   vfs:demo-write     — write a test file to mem://
//   vfs:demo-read      — read it back
//   vfs:demo-delete    — delete it
//   vfs:audio-play     — load src= from VFS and play via SDL3
//   vfs:audio-stop     — stop the SDL3 audio stream
//
// Audio via VFS src=
// ──────────────────
//   The audio node below starts with an empty src=.  When you click a .wav
//   file in the browser, the behavior writes the VFS URI into src= and the
//   play button reads it back:
//
//     audio(id="vfs-audio" src="asset://audio/click.wav")
//
//   You can also hardcode a VFS URI here — jade_host will NOT mangle it
//   because resolveAssetPaths skips any path that contains "://".
// =============================================================================

col(id="root" flexGrow="1")

  // ── Main content — three-column layout ─────────────────────────────────────
  row(flexGrow="1")

    // ── Left: mount scheme selector ──────────────────────────────────────────
    col.sidebar(width="160")

      div.section-title MOUNTS
      div.divider

      col(id="vfs-schemes" flexGrow="1" gap="2")

    // ── Centre: breadcrumb + file list + content viewer ──────────────────────
    col(flexGrow="1")

      // Breadcrumb bar
      row.breadcrumb(height="32" alignItems="center")
        div(id="vfs-path" flexGrow="1") —
        div.icon-btn(onclick="vfs:refresh") ↺

      div.divider

      // Two-panel split: file list (left) | content viewer (right)
      row(flexGrow="1")

        // File list
        col.file-list-panel(width="220")
          div.file-list-header FILES
          col(id="vfs-file-list" flexGrow="1" gap="2" padding="8")

        div.vdivider

        // Content viewer
        col.content-panel(flexGrow="1" padding="12")
          div.section-title CONTENT
          div(id="vfs-content-title" height="18") select a file
          div.thin-divider
          div(id="vfs-content" flexGrow="1")

    // ── Right: demo operations + VFS info ────────────────────────────────────
    col.ops-panel(width="180")

      div.section-title DEMO OPS
      div.divider

      div.op-btn(onclick="vfs:demo-write") ✎  write test file
      div.op-btn(onclick="vfs:demo-read")  ↓  read back
      div.op-btn.danger(onclick="vfs:demo-delete") ✕  delete

      div.divider

      div.section-title VFS INFO
      div.vfs-info(id="vfs-vfs-info") —

      div.divider

      div.section-title STATUS
      div(id="vfs-status") ready

  // ── Audio player footer ─────────────────────────────────────────────────────
  //
  //   audio(src="") is the data node.  Its src= attribute is a VFS URI:
  //
  //     • Set at runtime by the behavior when a .wav is selected
  //     • Or hardcoded here, e.g.  src="asset://audio/click.wav"
  //
  //   jade_host preserves scheme:// URIs unchanged (resolveAssetPaths skips
  //   any src= that contains "://"), so VFS URIs are safe to use directly.
  // ───────────────────────────────────────────────────────────────────────────
  div.audio-divider

  row.audio-bar(height="56" alignItems="center" gap="12")

    // Invisible data node — src= is set by the behavior (or hardcode a VFS URI)
    audio(id="vfs-audio" src="" height="0" width="0")

    div.audio-icon ♪

    col.audio-info(flexGrow="1" gap="2")
      div(id="vfs-audio-title").audio-title — no audio loaded —
      div.audio-hint Select a .wav in the browser, then press ▶

    div.audio-ctl(onclick="vfs:audio-play") ▶
    div.audio-ctl(onclick="vfs:audio-stop") ■

    div(id="vfs-audio-badge").audio-badge stopped
