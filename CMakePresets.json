{
  "version": 6,
  "cmakeMinimumRequired": {
    "major": 3,
    "minor": 25,
    "patch": 0
  },
  "configurePresets": [
    {
      "name": "default",
      "displayName": "Default (System Toolchain)",
      "description": "Standard build using system-provided C++23 compiler",
      "binaryDir": "${sourceDir}/build",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "BUILD_TESTING": "ON",
        "BUILD_PYTHON_BINDINGS": "OFF"
      }
    },
    {
      "name": "macos-debug",
      "displayName": "macOS Debug",
      "description": "Debug build for macOS — vendored SDL_ttf deps, no system FreeType/HarfBuzz required. Use: cmake --preset macos-debug && cmake --build build -j",
      "binaryDir": "${sourceDir}/build",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "SDLTTF_VENDORED": "ON",
        "SDLTTF_FREETYPE_VENDORED": "ON",
        "SDLTTF_HARFBUZZ_VENDORED": "ON"
      }
    },
    {
      "name": "macos-release",
      "displayName": "macOS Release",
      "description": "Optimised release build for macOS — vendored SDL_ttf deps.",
      "binaryDir": "${sourceDir}/build",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "SDLTTF_VENDORED": "ON",
        "SDLTTF_FREETYPE_VENDORED": "ON",
        "SDLTTF_HARFBUZZ_VENDORED": "ON"
      }
    },
    {
      "name": "llvm22-custom",
      "displayName": "LLVM 22 Custom Toolchain",
      "description": "Uses the local LLVM 22.1.1 toolchain for C++23 development",
      "inherits": "default",
      "cacheVariables": {
        "CMAKE_C_COMPILER": "$env{HOME}/toolchains/llvm-22/bin/clang",
        "CMAKE_CXX_COMPILER": "$env{HOME}/toolchains/llvm-22/bin/clang++",
        "CMAKE_CXX_FLAGS": "-stdlib=libc++ -nostdinc++ -I$env{HOME}/toolchains/llvm-22/include/c++/v1",
        "CMAKE_EXE_LINKER_FLAGS": "-stdlib=libc++ -lc++abi -L$env{HOME}/toolchains/llvm-22/lib -Wl,-rpath,$env{HOME}/toolchains/llvm-22/lib",
        "CMAKE_SHARED_LINKER_FLAGS": "-stdlib=libc++ -lc++abi -L$env{HOME}/toolchains/llvm-22/lib -Wl,-rpath,$env{HOME}/toolchains/llvm-22/lib",
        "CMAKE_EXPORT_COMPILE_COMMANDS": "ON"
      }
    },
    {
      "name": "llvm22-asan",
      "displayName": "LLVM 22 — ASan + UBSan",
      "description": "LLVM 22: AddressSanitizer + UndefinedBehaviorSanitizer via CMake options",
      "inherits": "llvm22-custom",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "SDLOS_ENABLE_ASAN":  "ON",
        "SDLOS_ENABLE_UBSAN": "ON"
      }
    },
    {
      "name": "asan-system",
      "displayName": "System Clang — ASan + UBSan",
      "description": "System toolchain: AddressSanitizer + UndefinedBehaviorSanitizer",
      "inherits": "default",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE":   "Debug",
        "SDLOS_ENABLE_ASAN":  "ON",
        "SDLOS_ENABLE_UBSAN": "ON"
      }
    },
    {
      "name": "tsan-system",
      "displayName": "System Clang — TSan",
      "description": "System toolchain: ThreadSanitizer for data-race detection",
      "inherits": "default",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE":  "Debug",
        "SDLOS_ENABLE_TSAN": "ON"
      }
    },
    {
      "name": "macos-tidy",
      "displayName": "macOS — clang-tidy",
      "description": "macOS debug build with clang-tidy running on every C++ TU",
      "inherits": "macos-debug",
      "cacheVariables": {
        "SDLOS_ENABLE_CLANG_TIDY": "ON"
      }
    },
    {
      "name": "ci-ubuntu",
      "displayName": "CI Ubuntu Configuration",
      "description": "Configuration for GitHub Actions Ubuntu 24.04 with Clang 22 from apt.llvm.org",
      "inherits": "default",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "CMAKE_C_COMPILER": "clang-22",
        "CMAKE_CXX_COMPILER": "clang++-22",
        "DISABLE_ONNX": "ON"
      }
    },
    {
      "name": "ios-xcode-debug",
      "displayName": "iOS Debug (Xcode)",
      "description": "CMake + Xcode targeting iOS arm64. IMPORTANT: use config/config-ios-xcode.sh (it passes --fresh) or delete build/ios/ before re-configuring to avoid stale BUILD_SHARED_LIBS cache entries causing .dylib link errors.",
      "generator": "Xcode",
      "binaryDir": "${sourceDir}/build/ios",
      "cacheVariables": {
        "CMAKE_SYSTEM_NAME": "iOS",
        "CMAKE_OSX_ARCHITECTURES": "arm64",
        "CMAKE_OSX_DEPLOYMENT_TARGET": "16.0",
        "CMAKE_BUILD_TYPE": "Debug",
        "BUILD_SHARED_LIBS": {"type": "BOOL", "value": "OFF"},
        "SDL_SHARED": {"type": "BOOL", "value": "OFF"},
        "SDL_STATIC": {"type": "BOOL", "value": "ON"},
        "SDL_TEST_LIBRARY": {"type": "BOOL", "value": "OFF"},
        "SDLTTF_VENDORED": {"type": "BOOL", "value": "ON"},
        "SDLTTF_FREETYPE_VENDORED": {"type": "BOOL", "value": "ON"},
        "SDLTTF_HARFBUZZ_VENDORED": {"type": "BOOL", "value": "ON"},
        "SDLTTF_SHARED": {"type": "BOOL", "value": "OFF"},
        "SDLTTF_STATIC": {"type": "BOOL", "value": "ON"},
        "SDLIMAGE_SHARED": {"type": "BOOL", "value": "OFF"},
        "SDLIMAGE_STATIC": {"type": "BOOL", "value": "ON"},
        "SDLMIXER_SHARED": {"type": "BOOL", "value": "OFF"},
        "SDLMIXER_STATIC": {"type": "BOOL", "value": "ON"},
        "SDLOS_ENABLE_TESTS": {"type": "BOOL", "value": "OFF"},
        "SDLOS_IOS_BUNDLE_PREFIX": "dev.sdlos"
      }
    },
    {
      "name": "ios-xcode-release",
      "displayName": "iOS Release (Xcode)",
      "description": "Release build for iOS. Set SDLOS_IOS_TEAM to sign automatically. Use config/config-ios-xcode.sh or delete build/ios/ before re-configuring.",
      "inherits": "ios-xcode-debug",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "build-default",
      "configurePreset": "default"
    },
    {
      "name": "build-macos-debug",
      "configurePreset": "macos-debug"
    },
    {
      "name": "build-macos-release",
      "configurePreset": "macos-release"
    },
    {
      "name": "build-llvm22",
      "configurePreset": "llvm22-custom"
    },
    {
      "name": "build-llvm22-asan",
      "configurePreset": "llvm22-asan"
    },
    {
      "name": "build-asan-system",
      "configurePreset": "asan-system"
    },
    {
      "name": "build-tsan-system",
      "configurePreset": "tsan-system"
    },
    {
      "name": "build-macos-tidy",
      "configurePreset": "macos-tidy"
    },
    {
      "name": "build-ci",
      "configurePreset": "ci-ubuntu"
    },
    {
      "name": "build-ci-test",
      "configurePreset": "ci-ubuntu",
      "targets": ["all"]
    },
    {
      "name": "build-ios-debug",
      "configurePreset": "ios-xcode-debug"
    },
    {
      "name": "build-ios-release",
      "configurePreset": "ios-xcode-release"
    }
  ],
  "testPresets": [
    {
      "name": "test-default",
      "configurePreset": "default",
      "output": {
        "outputOnFailure": true
      }
    },
    {
      "name": "test-ci",
      "configurePreset": "ci-ubuntu",
      "output": {
        "outputOnFailure": true
      }
    }
  ]
}
