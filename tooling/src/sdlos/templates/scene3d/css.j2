/* =============================================================================
   {$name$}.css  —  Scene3D glTF viewer stylesheet
   Generated by sdlos create [{$template$}].  Edit freely.
   Loaded automatically by jade_host after the jade scene is parsed.
   =============================================================================

   CSS cascade in sdlos
   --------------------
   • Selectors use the same id= and class= attributes as the jade markup.
   • Property names are camelCase in C++ / snake-case in CSS:
       background-color → backgroundColor    border-radius → borderRadius
   • Trailing "px" is stripped: padding: 12px == padding: 12
   • Inline jade attributes override CSS — use CSS for defaults, jade for
     structural values (flexGrow, width, …).
   • :hover rules update on every pointer move — keep them cheap.
   • :active rules drive toggle-group radio state.

   HiDPI / Retina
   --------------
   All values are in LOGICAL pixels.  SDLRenderer multiplies by pixel_scale
   before writing to the GPU — you never need to know the physical resolution.

   Design tokens
   -------------
   Background   #0d0d12   — near-black canvas
   Surface      #ffffff0a — glass panel fill  (5 % white)
   Surface-hi   #ffffff14 — slightly brighter glass
   Accent       #6366f1   — indigo-500
   Accent-dim   #6366f133 — 20 % accent
   Text         #e2e8f0   — body  (slate-200)
   Text-muted   #64748b   — muted (slate-500)
   Text-dim     #94a3b8   — dim   (slate-400)
   Separator    #ffffff20 — 12 % white divider
   ============================================================================= */

/* ── Window root ──────────────────────────────────────────────────────────── */

#root {
    background-color: #0d0d12;
    color: #e2e8f0;
}

/* ── 3-D viewport ─────────────────────────────────────────────────────────── */

/* The scene3d node itself — fills its allotted column flex space.           */
/* display: block keeps it visible; behaviour sets display: none to hide it. */

#{$name$}-3d {
    background-color: #090910;
}

/* ── Sidebar container ────────────────────────────────────────────────────── */

.sidebar {
    background-color: #ffffff0a;
    padding: 12;
    gap: 6;
}

/* ── Section headings ─────────────────────────────────────────────────────── */

.section-title {
    height: 14;
    font-size: 10;
    color: #6366f1;
    font-weight: bold;
}

/* ── Dividers ─────────────────────────────────────────────────────────────── */

.divider {
    height: 1;
    background-color: #ffffff20;
}

/* ── Label toggle chips ───────────────────────────────────────────────────── */
/*
   Each chip controls whether the 2-D label overlay for one mesh is visible.
   onclick fires  {$name$}:toggle-label  with the mesh id as payload.
*/

.label-toggle {
    height: 28;
    padding: 0 10;
    border-radius: 4;
    font-size: 12;
    color: #94a3b8;
    background-color: #ffffff0a;
}

.label-toggle:hover {
    background-color: #6366f122;
    color: #c7d2fe;
}

.label-toggle:active {
    background-color: #6366f133;
    color: #a5b4fc;
}

/* ── Theme chips ─────────────────────────────────────────────────────────── */
/*
   Clicking a theme chip fires  {$name$}:theme  with the theme name as payload.
   The behavior sets --label-bg / --label-color CSS custom props on each label.
*/

.theme-chip {
    height: 28;
    padding: 0 10;
    border-radius: 4;
    font-size: 12;
    color: #94a3b8;
    background-color: #ffffff0a;
}

.theme-chip:hover {
    background-color: #ffffff14;
    color: #e2e8f0;
}

.theme-chip:active {
    background-color: #6366f133;
    color: #a5b4fc;
}

/* ── Camera orbit buttons ─────────────────────────────────────────────────── */

.cam-btn {
    height: 28;
    padding: 0 10;
    border-radius: 4;
    font-size: 13;
    color: #94a3b8;
    background-color: #ffffff0a;
}

.cam-btn:hover {
    background-color: #ffffff18;
    color: #e2e8f0;
}

/* ── 2-D label overlays ───────────────────────────────────────────────────── */
/*
   Label nodes are created at runtime by the behaviour with LayoutKind::None.
   They are absolutely positioned over the 3-D AABB centroid each frame.
   All four themes are defined here; the behaviour writes the chosen
   background-color / color directly via setStyle() to override these.
*/

.mesh-label {
    border-radius: 4;
    font-size: 11;
    font-weight: bold;
    background-color: #6366f1cc;
    color: #ffffff;
    padding: 3 8;
}

/* Indigo (default) */
.mesh-label.theme-indigo {
    background-color: #6366f1cc;
    color: #ffffff;
}

/* Amber */
.mesh-label.theme-amber {
    background-color: #d97706cc;
    color: #fff7ed;
}

/* Emerald */
.mesh-label.theme-emerald {
    background-color: #059669cc;
    color: #ecfdf5;
}

/* Rose */
.mesh-label.theme-rose {
    background-color: #e11d48cc;
    color: #fff1f2;
}

/* Invisible — used when a label is toggled off */
.mesh-label.hidden {
    background-color: #00000000;
    color: #00000000;
}

/* ── Status bar ───────────────────────────────────────────────────────────── */

.status-bar {
    height: 22;
    padding: 0 12;
    background-color: #ffffff08;
    font-size: 11;
    color: #64748b;
}

#{$name$}-status {
    color: #4ade80;
    font-size: 11;
}

/* ── Hover tooltip ────────────────────────────────────────────────────────── */
/*
   #<name>-tooltip is injected at runtime as a LayoutKind::None div.
   It appears at the pointer position when hovering over a 3-D mesh.
*/

#{$name$}-tooltip {
    border-radius: 4;
    font-size: 11;
    background-color: #1e1b4bdd;
    color: #c7d2fe;
    padding: 4 10;
    border-width: 1;
    border-color: #6366f144;
}

/* ── Info panel text ──────────────────────────────────────────────────────── */

.info-key {
    height: 18;
    font-size: 10;
    color: #64748b;
}

.info-val {
    height: 18;
    font-size: 11;
    color: #c7d2fe;
}

.mesh-count-badge {
    height: 20;
    padding: 2 8;
    border-radius: 10;
    font-size: 10;
    background-color: #6366f133;
    color: #a5b4fc;
}

/* ── Camera parameter controls ────────────────────────────────────────────── */
/*
   param-row / param-btn / param-val / param-label mirror the sidebar orbit
   controls in the jade template.  param-btn is an alias for cam-btn.
*/

.param-label {
    height: 14;
    font-size: 10;
    color: #64748b;
}

.param-row {
    gap: 4;
    alignItems: center;
}

.param-btn {
    height: 28;
    width: 28;
    border-radius: 4;
    font-size: 15;
    color: #94a3b8;
    background-color: #ffffff0a;
}

.param-btn:hover {
    background-color: #ffffff18;
    color: #e2e8f0;
}

.param-btn:active {
    background-color: #6366f133;
    color: #a5b4fc;
}

.param-val {
    height: 28;
    font-size: 12;
    color: #c7d2fe;
    background-color: #ffffff05;
    border-radius: 3;
}

/* ── Action button (reset camera, etc.) ──────────────────────────────────── */

.action-btn {
    height: 30;
    padding: 4 10;
    border-radius: 4;
    font-size: 12;
    color: #a5b4fc;
    background-color: #6366f11a;
}

.action-btn:hover {
    background-color: #6366f133;
    color: #c7d2fe;
}

.action-btn:active {
    background-color: #6366f150;
    color: #e0e7ff;
}

/* ── Generic toggle chip (labels-toggle, theme-toggle) ───────────────────── */

.chip {
    height: 28;
    padding: 0 10;
    border-radius: 4;
    font-size: 12;
    color: #94a3b8;
    background-color: #ffffff0a;
}

.chip:hover {
    background-color: #6366f122;
    color: #c7d2fe;
}

.chip:active {
    background-color: #6366f133;
    color: #a5b4fc;
}

/* ── Colour swatches (style-guide row) ────────────────────────────────────── */
/*
   Small clickable squares that fire  {$name$}:cycle-theme  with a data-value
   payload ("default" | "accent" | "muted" | "danger" | "bright").
   Each .sw-* class provides the fill colour.
*/

.swatch {
    width: 18;
    height: 18;
    border-radius: 4;
}

.swatch:hover {
    border-width: 2;
    border-color: #ffffff40;
}

.sw-default {
    background-color: #6366f1;
}

.sw-accent {
    background-color: #059669;
}

.sw-muted {
    background-color: #475569;
}

.sw-danger {
    background-color: #e11d48;
}

.sw-bright {
    background-color: #0ea5e9;
}

/* ── Sidebar info text ────────────────────────────────────────────────────── */

#{$name$}-info {
    font-size: 10;
    color: #64748b;
}
