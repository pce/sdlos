// =============================================================================
// {$name$}.jade  —  UI scene for the {$name$} app
// Generated by sdlos create [{$template$}].  Edit freely.
// CSS styles → {$name$}.css  (loaded automatically by jade_host)
// =============================================================================
//
// Layout: left sidebar (controls) | 3-D canvas with floating label overlay
//
// Node ID reference  (used by tree.findById() in the behavior)
// ────────────────────────────────────────────────────────────
//   {$name$}-3d            — scene3d node that owns the model (src= is overridden
//                             at runtime by the behavior to point at the binary-dir
//                             copy; the value here is the source-tree hint only)
//   {$name$}-canvas        — col that wraps the 3d node (fullscreen flex fill)
//   {$name$}-yaw           — current yaw value label in the sidebar
//   {$name$}-pitch         — current pitch value label in the sidebar
//   {$name$}-dist          — current distance value label in the sidebar
//   {$name$}-labels-toggle — chip button that toggles label visibility
//   {$name$}-theme-toggle  — chip button that cycles the label colour theme
//   {$name$}-info          — mesh count / status line at the bottom of the sidebar
//
// EventBus topics fired by this scene (onclick handlers)
// ───────────────────────────────────────────────────────
//   {$name$}:yaw-dec       — orbit yaw  –10 °
//   {$name$}:yaw-inc       — orbit yaw  +10 °
//   {$name$}:pitch-dec     — orbit pitch –5 °
//   {$name$}:pitch-inc     — orbit pitch  +5 °
//   {$name$}:dist-dec      — camera closer
//   {$name$}:dist-inc      — camera farther
//   {$name$}:toggle-labels — show / hide all floating labels
//   {$name$}:cycle-theme   — cycle label CSS theme (default → accent → danger → …)
//   {$name$}:reset-camera  — snap camera back to the default orbit pose
//
// How floating labels work
// ────────────────────────
// After GltfScene::attach() injects object3d proxy nodes into the tree, the
// behavior creates one div.mesh-label per proxy and appends it directly to
// root with LayoutKind::None (so it is invisible to the flex engine).
// GltfScene::tick() writes each proxy's projected screen-space AABB into
// proxy->x/y/w/h every frame; the root->update callback reads those values
// and repositions the matching label divs above each AABB centroid.
// Labels are therefore true HUD elements: they sit in the 2-D UI pass on
// top of the 3-D pre-pass, styled entirely with CSS (.mesh-label + themes).
//
// Dropping a different model
// ──────────────────────────
// Place any .glb file in data/models/ and update the src= attribute on the
// scene3d node below (or change the override in {$name$}_behavior.cxx).
// The behavior normalises the Blender mesh name to a CSS id automatically:
//   "Teapot Body" → id="teapot-body",  "Lid" → id="lid"
// =============================================================================

row(id="root" flexGrow="1")

  // ── Left: camera orbit + label controls ───────────────────────────────────
  col.sidebar(width="200" gap="6" padding="12")

    div.section-title CAMERA

    // Yaw
    div.param-label Yaw
    row.param-row
      div.param-btn(onclick="{$name$}:yaw-dec"  data-axis="yaw") −
      div.param-val(id="{$name$}-yaw" flexGrow="1") 20°
      div.param-btn(onclick="{$name$}:yaw-inc"  data-axis="yaw") +

    // Pitch
    div.param-label Pitch
    row.param-row
      div.param-btn(onclick="{$name$}:pitch-dec" data-axis="pitch") −
      div.param-val(id="{$name$}-pitch" flexGrow="1") 18°
      div.param-btn(onclick="{$name$}:pitch-inc" data-axis="pitch") +

    // Distance
    div.param-label Distance
    row.param-row
      div.param-btn(onclick="{$name$}:dist-dec"  data-axis="dist") −
      div.param-val(id="{$name$}-dist" flexGrow="1") 5.0
      div.param-btn(onclick="{$name$}:dist-inc"  data-axis="dist") +

    div.divider

    div.action-btn(onclick="{$name$}:reset-camera") ⊙  Reset camera

    div.divider
    div.section-title LABELS

    div.chip(id="{$name$}-labels-toggle" onclick="{$name$}:toggle-labels") ◉  Labels visible
    div.chip(id="{$name$}-theme-toggle"  onclick="{$name$}:cycle-theme")   ◈  Theme: default

    div.divider
    div.section-title STYLE GUIDE

    // Quick colour swatches — drive CSS custom properties on the label root.
    // Each swatch publishes a theme name the behavior forwards to applyCSS().
    row(gap="6" padding="2 0")
      div.swatch.sw-default(onclick="{$name$}:cycle-theme" data-value="default")
      div.swatch.sw-accent( onclick="{$name$}:cycle-theme" data-value="accent")
      div.swatch.sw-muted(  onclick="{$name$}:cycle-theme" data-value="muted")
      div.swatch.sw-danger( onclick="{$name$}:cycle-theme" data-value="danger")
      div.swatch.sw-bright( onclick="{$name$}:cycle-theme" data-value="bright")

    div.divider

    div(id="{$name$}-info" height="32" fontSize="10") —

  // ── Right: full-height 3-D viewport ───────────────────────────────────────
  col(id="{$name$}-canvas" flexGrow="1" backgroundColor="#0b0b10")

    // The scene3d node is recognised by GltfScene::attach().
    // src= is intentionally a placeholder; the behavior overrides it to
    // the binary-dir path before calling attach() so the source-tree path
    // is never required to exist at runtime.
    //
    // Floating label divs (div.mesh-label, LayoutKind::None) are appended
    // directly to root by the behavior — NOT here — so they sit outside the
    // flex layout but their x/y values are viewport-relative.
    scene3d(id="{$name$}-3d"
            src="data/models/scene.glb"
            mesh-id="{$name$}-mesh"
            display="block"
            flexGrow="1")
