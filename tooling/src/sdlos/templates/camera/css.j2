/* {$name$}.css  —  generated by sdlos create  [camera]
 *
 * Property names use CSS kebab-case; jade_host converts them to camelCase
 * (background-color → backgroundColor, font-size → fontSize, …).
 * Trailing "px" is stripped automatically.
 *
 * Most layout values are set inline in {$name$}.jade for the camera template
 * since each panel has unique sizing.  Add class rules here when you refactor
 * repeated inline attrs into shared classes.
 */

/* ── Preset / filter chips ────────────────────────────────────────────────── */

.preset {
    border-radius: 6;
    padding: 6;
}

.preset:hover {
    background-color: #ffffff1a;
}

/* ── +/– stepper buttons ─────────────────────────────────────────────────── */

.param-btn {
    border-radius: 6;
}

.param-btn:hover {
    background-color: #ffffff40;
}

/* ── Dragnum value inputs ─────────────────────────────────────────────────── */

.param-val {
    border-radius: 6;
    background-color: #ffffff0a;
    color: #ffffffcc;
    font-size: 13;
}
