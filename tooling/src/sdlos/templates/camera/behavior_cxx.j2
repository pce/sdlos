// {$name$}_behavior.cxx  —  generated by sdlos create  [camera]
//
// Live video canvas + filter chips + dragnum parameter inputs.
//
// Customise
// ---------
//   1. Add / remove rows in k{$pascal_name$}Filters[].
//   2. Adjust the Param list in {$pascal_name$}State::params.
//   3. The raw SDL event hook at the bottom routes mouse/key events to all
//      NumberDragger widgets.  Add more handles to the capture list if you
//      add more dragnum inputs.
//
// Regeneration
// ------------
// Running  sdlos create {$name$} --overwrite  re-generates scaffold files.
// Everything between the  --- enter the forrest ---  and
// --- back to the sea ---  markers is preserved verbatim.
//
// This file is #include-d into jade_host.cxx at compile time.

#include "widgets/number_dragger.hh"

#include <algorithm>
#include <charconv>
#include <cstdio>
#include <memory>
#include <string>
#include <vector>

namespace {

// ── Filter catalogue ──────────────────────────────────────────────────────────

struct Filter {
    std::string display;   // data-value= on the chip
    std::string shader;    // _shader attr value  (empty = pass-through, no fx)
    float       p0;        // default _shader_param0
};

// --- enter the forrest ---

const Filter k{$pascal_name$}Filters[] = {
    { "none",      "",          0.f },
    { "cinematic", "cinematic", 1.f },
};

// --- back to the sea ---

// ── Parameter descriptor ──────────────────────────────────────────────────────

struct Param {
    std::string style_key;    // _shader_param0 / _shader_param1 …
    std::string lbl_id;       // label node id
    std::string dragger_id;   // dragnum input id
    float       step, min_v, max_v;
    pce::sdlos::NodeHandle label_h   = pce::sdlos::k_null_handle;
    pce::sdlos::NodeHandle dragger_h = pce::sdlos::k_null_handle;
};

struct {$pascal_name$}State {
    std::string active_filter = "none";

    std::vector<Param> params = {
        { "_shader_param0", "lbl-p0", "val-p0", 0.05f, 0.f, 1.f },
    };

    pce::sdlos::NodeHandle canvas_h      = pce::sdlos::k_null_handle;
    pce::sdlos::NodeHandle active_name_h = pce::sdlos::k_null_handle;
};

// ── Helpers ───────────────────────────────────────────────────────────────────

static void setAttr(pce::sdlos::RenderTree& tree,
                    pce::sdlos::NodeHandle   h,
                    const std::string& key, const std::string& val)
{
    if (pce::sdlos::RenderNode* n = tree.node(h)) {
        n->setStyle(key, val);
        n->dirty_render = true;
    }
}

static void highlightFilter(pce::sdlos::RenderTree& tree,
                              const std::vector<pce::sdlos::NodeHandle>& chips,
                              const std::string& active)
{
    for (auto h : chips) {
        if (pce::sdlos::RenderNode* n = tree.node(h)) {
            const bool on = (n->style("data-value") == active);
            n->setStyle("backgroundColor", on ? "#6366f133" : "#ffffff00");
            n->dirty_render = true;
        }
    }
}

static void applyFilter(pce::sdlos::RenderTree& tree,
                         {$pascal_name$}State& s,
                         const std::string& filter_name,
                         const std::vector<pce::sdlos::NodeHandle>& chips)
{
    const Filter* f = nullptr;
    for (const auto& fi : k{$pascal_name$}Filters)
        if (fi.display == filter_name) { f = &fi; break; }

    if (f) {
        s.active_filter = filter_name;
        if (s.canvas_h.valid()) {
            setAttr(tree, s.canvas_h, "_shader", f->shader);
            char buf[32];
            std::snprintf(buf, sizeof(buf), "%.4g", static_cast<double>(f->p0));
            setAttr(tree, s.canvas_h, "_shader_param0", buf);
        }
        if (!s.params.empty() && s.params[0].dragger_h.valid()) {
            pce::sdlos::widgets::NumberDragger nd{tree, s.params[0].dragger_h};
            nd.setValue(f->p0);
        }
    }

    highlightFilter(tree, chips, filter_name);

    if (s.active_name_h.valid())
        setAttr(tree, s.active_name_h, "text", filter_name);
}

} // namespace

// ── jade_app_init ─────────────────────────────────────────────────────────────

void jade_app_init(pce::sdlos::RenderTree&               tree,
                   pce::sdlos::NodeHandle                 root,
                   pce::sdlos::IEventBus&                 bus,
                   pce::sdlos::SDLRenderer&               renderer,
                   std::function<bool(const SDL_Event&)>& out_handler)
{
    // Upgrade input[type=dragnum] nodes before looking them up.
    pce::sdlos::widgets::bindDragNumWidgets(tree, root);

    auto state = std::make_shared<{$pascal_name$}State>();

    state->canvas_h      = tree.findById(root, "{$name$}-canvas");
    state->active_name_h = tree.findById(root, "active-name");
    for (auto& p : state->params) {
        p.label_h   = tree.findById(root, p.lbl_id);
        p.dragger_h = tree.findById(root, p.dragger_id);
    }

    const auto chips = tree.findByClass(root, "preset");

    sdlos_log("[{$name$}] canvas=" + std::string(state->canvas_h.valid() ? "ok" : "MISSING")
              + "  filters=" + std::to_string(chips.size()));

    // Wire each dragnum's on_change → push value to the shader canvas.
    for (auto& p : state->params) {
        if (!p.dragger_h.valid()) continue;
        pce::sdlos::widgets::NumberDragger nd{tree, p.dragger_h};
        if (auto* st = nd.getState()) {
            const std::string key = p.style_key;
            pce::sdlos::NodeHandle cv = state->canvas_h;
            st->cfg.on_change = [&tree, cv, key](float v) {
                char buf[32];
                std::snprintf(buf, sizeof(buf), "%.4g", static_cast<double>(v));
                if (pce::sdlos::RenderNode* n = tree.node(cv)) {
                    n->setStyle(key, buf);
                    n->dirty_render = true;
                }
            };
        }
    }

    // Open the first available camera device.
    if (auto* vt = renderer.GetVideoTexture()) {
        const auto devs = vt->enumerate();
        if (!devs.empty()) {
            vt->openByIndex(0);
            if (auto h = tree.findById(root, "{$name$}-device-name"); h.valid())
                setAttr(tree, h, "text", devs[0].name);
        }
    }

    bus.subscribe("{$name$}:filter",
        [&tree, state, chips](const std::string& f) {
            applyFilter(tree, *state, f, chips);
        });

    auto paramIdx = [](const std::string& k) -> int {
        if (k == "p0") return 0;
        return -1;
    };

    bus.subscribe("{$name$}:inc",
        [&tree, state, paramIdx](const std::string& key) {
            const int i = paramIdx(key);
            if (i < 0) return;
            auto& p = state->params[static_cast<std::size_t>(i)];
            if (!p.dragger_h.valid()) return;
            pce::sdlos::widgets::NumberDragger nd{tree, p.dragger_h};
            nd.setValue(std::clamp(nd.getValue() + p.step, p.min_v, p.max_v));
        });

    bus.subscribe("{$name$}:dec",
        [&tree, state, paramIdx](const std::string& key) {
            const int i = paramIdx(key);
            if (i < 0) return;
            auto& p = state->params[static_cast<std::size_t>(i)];
            if (!p.dragger_h.valid()) return;
            pce::sdlos::widgets::NumberDragger nd{tree, p.dragger_h};
            nd.setValue(std::clamp(nd.getValue() - p.step, p.min_v, p.max_v));
        });

    // ── User extension point ───────────────────────────────────────────────────
    // --- enter the forrest ---

    // --- back to the sea ---

    // ── Raw SDL event hook ────────────────────────────────────────────────────
    // Scales logical → physical coords then forwards to all dragnum widgets.
    // Extend the capture list below if you add more dragnum inputs.
    pce::sdlos::NodeHandle dh0 = state->params.empty()
                                     ? pce::sdlos::k_null_handle
                                     : state->params[0].dragger_h;

    out_handler =
        [&tree, &renderer, dh0](const SDL_Event& ev) mutable -> bool
    {
        const float sx = renderer.pixelScaleX();
        const float sy = renderer.pixelScaleY();

        SDL_Event sc = ev;
        switch (ev.type) {
        case SDL_EVENT_MOUSE_BUTTON_DOWN:
        case SDL_EVENT_MOUSE_BUTTON_UP:
            sc.button.x = ev.button.x * sx;
            sc.button.y = ev.button.y * sy;
            break;
        case SDL_EVENT_MOUSE_MOTION:
            sc.motion.x = ev.motion.x * sx;
            sc.motion.y = ev.motion.y * sy;
            break;
        default: break;
        }

        bool consumed = false;
        if (dh0.valid()) {
            pce::sdlos::widgets::NumberDragger nd{tree, dh0};
            consumed |= nd.handleEvent(sc);
        }
        return consumed;
    };

    applyFilter(tree, *state, state->active_filter, chips);
}
