// =============================================================================
// {$name$}.jade  —  UI scene for the {$name$} app
// Generated by sdlos create [{$template$}].  Edit freely.
// CSS styles → {$name$}.css  (loaded automatically by jade_host)
// =============================================================================
//
// Layout: three-column flex row — filter chips | live video canvas | dragnum params
//
// Node ID reference  (used by tree.findById() in the behavior)
// ────────────────────────────────────────────────────────────
//   root                   — window root row  (full screen, dark canvas)
//   {$name$}-canvas        — centre video div  (receives _video + _shader attrs)
//   active-name            — text div showing the name of the active filter
//   {$name$}-device-name   — text div populated at runtime with the opened
//                             camera device name (set by jade_app_init)
//   lbl-p0                 — intensity parameter label
//   val-p0                 — dragnum input for _shader_param0 (intensity)
//
// EventBus topics fired by this scene (onclick handlers)
// ───────────────────────────────────────────────────────
//   {$name$}:filter   — user tapped a filter chip
//                        payload = data-value attribute of the chip
//                        ("none", "cinematic", or any name you add)
//   {$name$}:inc      — +  button tapped
//                        payload = "p0"
//   {$name$}:dec      — –  button tapped
//                        payload = "p0"
//
// Adding filters
// ──────────────
//   1. Add a div.preset chip here with onclick="{$name$}:filter" and a unique
//      data-value= matching the shader stem you want to apply.
//   2. Add a matching row to k{$pascal_name$}Filters[] in {$name$}_behavior.cxx.
//   3. Drop the .metal shader in data/shaders/msl/<stem>.frag.metal.
// =============================================================================

row(id="root" flexGrow="1" backgroundColor="#0d0d12")

  // ── Left: filter chips ─────────────────────────────────────────────────────
  col(width="180" gap="4" padding="12" backgroundColor="#ffffff0a")

    div(height="16" color="#6366f1" fontSize="11") FILTERS
    div(height="1" backgroundColor="#ffffff20")

    div.preset(height="34" onclick="{$name$}:filter" data-value="none"      color="#cccccc") No Filter
    div.preset(height="34" onclick="{$name$}:filter" data-value="cinematic" color="#cccccc") Cinematic

  // ── Centre: live camera canvas ─────────────────────────────────────────────
  // _video="camera://0"  opens the first system camera device.
  // _shader=             names the fragment shader applied on top of the feed.
  // Swap _shader="" (empty) to show a raw passthrough with no effect.
  col(flexGrow="1" padding="8")
    div(id="{$name$}-canvas"
        _video="camera://0"
        _shader="cinematic"
        flexGrow="1"
        backgroundColor="#111111")

  // ── Right: dragnum parameter controls ─────────────────────────────────────
  // input[type=dragnum] is upgraded to a NumberDragger widget by
  // bindDragNumWidgets() in jade_app_init — drag left/right to scrub the value.
  col(width="200" gap="2" padding="12" backgroundColor="#ffffff0a")

    div(id="active-name" height="18" color="#a5b4fc" fontSize="13") none
    div(height="1" backgroundColor="#ffffff20")

    div(id="lbl-p0" height="18" color="#ffffff66" fontSize="11") Intensity
    row(height="28" gap="4")
      div.param-btn(id="btn-p0-dec" width="28" height="28"
                    onclick="{$name$}:dec" data-value="p0"
                    backgroundColor="#ffffff1a" color="#ffffff") -
      input.param-val(type="dragnum" id="val-p0"
                      flexGrow="1" height="28"
                      min="0" max="1" step="0.05" value="1.0")
      div.param-btn(id="btn-p0-inc" width="28" height="28"
                    onclick="{$name$}:inc" data-value="p0"
                    backgroundColor="#ffffff1a" color="#ffffff") +

    div(height="1" backgroundColor="#ffffff20")
    div(height="18" color="#ffffff44" fontSize="11") DEVICE
    div(id="{$name$}-device-name" height="18" color="#888888" fontSize="12") —
