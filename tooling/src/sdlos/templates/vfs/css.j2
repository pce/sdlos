/* {$name$}.css — {$template$} app stylesheet
   Generated by sdlos create.  Edit freely.
   Loaded automatically by jade_host after the jade scene is parsed.

   Layout
   ------
   col#root
   ├── row (flexGrow)
   │   ├── col.sidebar         — scheme selector chips
   │   ├── col (flexGrow)
   │   │   ├── row.breadcrumb  — current path + refresh button
   │   │   └── row (flexGrow)
   │   │       ├── col.file-list-panel
   │   │       └── col.content-panel
   │   └── col.ops-panel       — demo ops + VFS info + status
   └── row.audio-bar           — audio player footer

   Design tokens
   -------------
   Background  #0d0d12    near-black canvas
   Surface A   #ffffff0a  glass side-panel fill  (4 % white)
   Surface B   #ffffff05  file list fill         (2 % white)
   Accent      #6366f1    indigo-500
   Accent dim  #6366f133  accent at 20 % opacity
   Text        #e2e8f0    body text  (slate-200)
   Dim text    #94a3b8    muted label  (slate-400)
   Faint text  #64748b    placeholder  (slate-500)
   Separator   #ffffff20  12 % white divider
   OK green    #4ade80    success / ready status
   Error red   #f87171    failure / warning status
   Dir blue    #60a5fa    directory entries
   Audio gold  #fbbf24    audio accent  (amber-400)
*/

#root {
    background-color: #0d0d12;
    color: #e2e8f0;
    font-size: 13;
}

.sidebar {
    background-color: #ffffff0a;
    padding: 12;
    gap: 4;
}

.ops-panel {
    background-color: #ffffff0a;
    padding: 12;
    gap: 8;
}

.file-list-panel {
    background-color: #ffffff05;
    gap: 0;
}

.content-panel {
    padding: 12;
    gap: 6;
}

.section-title {
    height: 14;
    font-size: 10;
    color: #6366f1;
    font-weight: bold;
}

.divider {
    height: 1;
    background-color: #ffffff20;
}

.vdivider {
    width: 1;
    background-color: #ffffff20;
}

.thin-divider {
    height: 1;
    background-color: #ffffff18;
}

.breadcrumb {
    background-color: #ffffff08;
    padding-left: 12;
    padding-right: 8;
}

#{$name$}-path {
    color: #94a3b8;
    font-size: 12;
}

.icon-btn {
    width: 28;
    height: 24;
    background-color: #6366f133;
    color: #6366f1;
    font-size: 14;
    border-radius: 4;
}

.icon-btn:hover {
    background-color: #6366f155;
    color: #a5b4fc;
}

.scheme-chip {
    height: 30;
    padding: 6;
    border-radius: 4;
    font-size: 12;
    color: #94a3b8;
    background-color: #ffffff0a;
}

.scheme-chip:hover {
    background-color: #6366f122;
    color: #c7d2fe;
}

.scheme-chip.active {
    background-color: #6366f133;
    color: #a5b4fc;
    border-color: #6366f155;
    border-width: 1;
}

.file-list-header {
    height: 14;
    font-size: 10;
    color: #6366f1;
    font-weight: bold;
    padding-left: 8;
    padding-right: 8;
    padding-top: 10;
    padding-bottom: 4;
}

.file-entry {
    height: 26;
    padding: 4;
    border-radius: 3;
    font-size: 12;
    color: #94a3b8;
    background-color: transparent;
}

.file-entry:hover {
    background-color: #ffffff0f;
    color: #e2e8f0;
}

.file-entry.selected {
    background-color: #6366f122;
    color: #a5b4fc;
}

.file-entry.is-dir {
    color: #60a5fa;
    font-weight: bold;
}

#{$name$}-content-title {
    height: 18;
    font-size: 11;
    color: #94a3b8;
}

#{$name$}-content {
    font-size: 12;
    color: #e2e8f0;
    padding: 4;
    border-radius: 4;
    background-color: #ffffff05;
}

.op-btn {
    height: 30;
    padding: 6;
    border-radius: 4;
    font-size: 12;
    color: #a5b4fc;
    background-color: #6366f11a;
}

.op-btn:hover {
    background-color: #6366f133;
    color: #c7d2fe;
}

.op-btn.danger {
    color: #fca5a5;
    background-color: #7f1d1d1a;
}

.op-btn.danger:hover {
    background-color: #7f1d1d44;
    color: #fecaca;
}

.vfs-info {
    font-size: 11;
    color: #64748b;
}

#{$name$}-status {
    font-size: 11;
    color: #4ade80;
}

.empty-hint {
    height: 24;
    font-size: 12;
    color: #64748b;
    padding: 4;
}

/* audio-bar — footer row with invisible data node, track info, controls */

.audio-divider {
    height: 1;
    background-color: #fbbf2430;
}

.audio-bar {
    background-color: #0d0d1a;
    padding-left: 16;
    padding-right: 16;
}

.audio-icon {
    width: 28;
    height: 28;
    font-size: 18;
    color: #fbbf24;
}

.audio-info {
    gap: 2;
}

.audio-title {
    font-size: 12;
    color: #e2e8f0;
    height: 16;
}

.audio-hint {
    font-size: 10;
    color: #64748b;
    height: 13;
}

.audio-ctl {
    width: 32;
    height: 32;
    border-radius: 6;
    font-size: 14;
    color: #fbbf24;
    background-color: #fbbf2420;
}

.audio-ctl:hover {
    background-color: #fbbf2440;
    color: #fde68a;
}

.audio-ctl:active {
    background-color: #fbbf2460;
    color: #fffbeb;
}

/* badge text changes at runtime: "stopped" | "ready" | "playing" */

.audio-badge {
    height: 20;
    padding: 4;
    border-radius: 10;
    font-size: 10;
    color: #64748b;
    background-color: #ffffff0a;
}

#{$name$}-audio-badge {
    color: #64748b;
}
