// {$name$}.jade  —  generated by sdlos create  [shader]
// Styles → {$name$}.css  (loaded automatically by jade_host)
//
// Layout: three-column — preset list | shader canvas | param controls.
// Add your shader names to the preset chips and to k{$pascal_name$}Presets[]
// in {$name$}_behavior.cxx.

row(id="root" flexGrow="1")

  // ── Left: shader preset list ───────────────────────────────────────────────
  col.sidebar(id="sidebar-presets" flexGrow="1")

    div.section-title Shaders
    div.divider

    div.preset(onclick="{$name$}:preset" data-value="preset_a" backgroundColor="#6366f133" color="#ffffff") Preset A
    div.preset(onclick="{$name$}:preset" data-value="preset_b") Preset B
    div.preset(onclick="{$name$}:preset" data-value="none") None

  // ── Centre: shader canvas ──────────────────────────────────────────────────
  // Use a plain div so the app launches without requiring any image asset.
  // To display an image behind the shader swap div → img and add src="...".
  col.main-panel(id="main-panel" flexGrow="5")
    div(id="{$name$}-canvas"
        flexGrow="1"
        _shader="preset_a"
        _shader_focusX="0.5"
        _shader_focusY="0.5"
        _shader_param0="1.0"
        _shader_param1="0.0"
        _shader_param2="0.0")

  // ── Right: parameter controls ──────────────────────────────────────────────
  col.sidebar(id="sidebar-params" flexGrow="1.2")

    div.section-title Params
    div.divider

    div(id="active-name")
    div(backgroundColor="#ffffff15" height="1")

    // Param 0 ────────────────────────────────────────────────────────────────
    div.param-label(id="lbl-p0") Param 0
    row.param-row
      div.param-btn(id="btn-p0-dec" onclick="{$name$}:dec" data-value="p0") -
      div.param-val(id="val-p0" flexGrow="1") 1.0
      div.param-btn(id="btn-p0-inc" onclick="{$name$}:inc" data-value="p0") +

    // Param 1 ────────────────────────────────────────────────────────────────
    div.param-label(id="lbl-p1") Param 1
    row.param-row
      div.param-btn(id="btn-p1-dec" onclick="{$name$}:dec" data-value="p1") -
      div.param-val(id="val-p1" flexGrow="1") 0.0
      div.param-btn(id="btn-p1-inc" onclick="{$name$}:inc" data-value="p1") +

    div(backgroundColor="#ffffff20" height="1")
    div(id="status")
